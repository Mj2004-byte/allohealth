# PostgreSQL via Supabase (use connection pooler URL for DATABASE_URL)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Groq — get free key from https://console.groq.com
GROQ_API_KEY=gsk_...

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Reservation hold time in minutes
RESERVATION_EXPIRY_MINUTES=10

# Secret for protecting cron endpoint (any random string)
CRON_SECRET=change-this-in-production
